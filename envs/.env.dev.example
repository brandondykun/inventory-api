# ---------------------------------------------------------------------------
# Development environment. Copy to envs/.env.dev (gitignored) and adjust.
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ENV=dev

SECRET_KEY=dev-insecure-secret-key-change-me
DEBUG=true
ALLOWED_HOSTS=*

# --- Database ---
POSTGRES_DB=api_dev
POSTGRES_USER=api
POSTGRES_PASSWORD=api
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

# --- API docs ---
ENABLE_API_DOCS=true
API_TITLE=API (dev)

# --- Auth / JWT ---
JWT_ACCESS_LIFETIME_MIN=15
JWT_REFRESH_LIFETIME_DAYS=7
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax

# --- CORS (credentialed; cookies require explicit origins) ---
# :8081 is Expo's web dev server; :3000 covers a typical separate web app.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081

# --- Email / account verification ---
# "optional" lets users log in before verifying; mail prints to the console in
# dev. Set to "mandatory" to require verification (and configure SMTP below).
ACCOUNT_EMAIL_VERIFICATION=optional
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@localhost

# --- Social sign-in (leave blank to disable a provider) ---
# Google: OAuth 2.0 Client ID from Google Cloud Console > Credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Apple (see README for how to obtain each value):
#   APPLE_CLIENT_ID   = Services ID (web) or app Bundle ID (native)
#   APPLE_TEAM_ID     = 10-char Apple Developer Team ID
#   APPLE_KEY_ID      = Key ID of the Sign in with Apple .p8 key
#   APPLE_PRIVATE_KEY = full contents of the .p8 file (newlines preserved)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

LOG_LEVEL=DEBUG
