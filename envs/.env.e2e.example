# ---------------------------------------------------------------------------
# End-to-end environment. Copy to envs/.env.e2e (gitignored).
# Production-like settings against an isolated database.
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.e2e
DJANGO_ENV=e2e

SECRET_KEY=e2e-secret-key-change-me
DEBUG=false
ALLOWED_HOSTS=*

POSTGRES_DB=api_e2e
POSTGRES_USER=api
POSTGRES_PASSWORD=api
POSTGRES_HOST=db
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

ENABLE_API_DOCS=true

JWT_ACCESS_LIFETIME_MIN=15
JWT_REFRESH_LIFETIME_DAYS=7
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax

# nginx terminates in front; keep ssl redirect off for local e2e over http.
SECURE_SSL_REDIRECT=false

CORS_ALLOWED_ORIGINS=http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:8080
LOG_LEVEL=INFO
