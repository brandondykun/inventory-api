# ---------------------------------------------------------------------------
# Test environment. Copy to envs/.env.test (gitignored).
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.test
DJANGO_ENV=test

# Test-only key. ≥32 bytes so JWT's HMAC signing doesn't warn (not a real secret).
SECRET_KEY=test-secret-key-not-for-production-use-0123456789
DEBUG=false
ALLOWED_HOSTS=*

POSTGRES_DB=api_test
POSTGRES_USER=api
POSTGRES_PASSWORD=api
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Celery runs eagerly in tests; broker URLs are unused but kept valid.
CELERY_TASK_ALWAYS_EAGER=true
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

ENABLE_API_DOCS=false
LOG_LEVEL=WARNING
