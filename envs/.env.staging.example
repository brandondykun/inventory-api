# ---------------------------------------------------------------------------
# Staging environment. Copy to envs/.env.staging (gitignored).
# Use real, secret values from your secrets manager — never commit them.
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.staging
DJANGO_ENV=staging

SECRET_KEY=__CHANGE_ME__
JWT_SIGNING_KEY=__CHANGE_ME__
DEBUG=false
ALLOWED_HOSTS=staging.example.com

POSTGRES_DB=api_staging
POSTGRES_USER=api_staging
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_HOST=db
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

ENABLE_API_DOCS=true

JWT_ACCESS_LIFETIME_MIN=15
JWT_REFRESH_LIFETIME_DAYS=7
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=Lax

SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000

CORS_ALLOWED_ORIGINS=https://staging.example.com
CSRF_TRUSTED_ORIGINS=https://staging.example.com
LOG_LEVEL=INFO
