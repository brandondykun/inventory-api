# ---------------------------------------------------------------------------
# Production environment. Copy to envs/.env.prod (gitignored).
# Populate from your secrets manager. Required secrets have NO defaults in
# config/settings/production.py — a missing value fails startup loudly.
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ENV=production

SECRET_KEY=__CHANGE_ME__
JWT_SIGNING_KEY=__CHANGE_ME__
DEBUG=false
ALLOWED_HOSTS=api.example.com

POSTGRES_DB=api
POSTGRES_USER=api
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_HOST=db
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

ENABLE_API_DOCS=false

JWT_ACCESS_LIFETIME_MIN=15
JWT_REFRESH_LIFETIME_DAYS=7
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=Lax
# Set if the SPA is served from a different subdomain than the API.
# AUTH_COOKIE_DOMAIN=.example.com

SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000

CORS_ALLOWED_ORIGINS=https://app.example.com
CSRF_TRUSTED_ORIGINS=https://app.example.com

# --- Rate limiting ---
# Trusted proxies in front of the app so throttles key on the real client IP.
# 1 = behind the bundled nginx; raise it if a CDN/LB also fronts the API.
NUM_PROXIES=1
# Strict per-IP limits on unauthenticated abuse vectors (defaults shown).
THROTTLE_LOGIN=10/min
THROTTLE_REGISTER=10/min

# --- Email / account verification ---
# Mandatory verification + real SMTP. A working mail server is required.
ACCOUNT_EMAIL_VERIFICATION=mandatory
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@example.com
EMAIL_HOST=__CHANGE_ME__
EMAIL_PORT=587
EMAIL_HOST_USER=__CHANGE_ME__
EMAIL_HOST_PASSWORD=__CHANGE_ME__
EMAIL_USE_TLS=true

# --- Social sign-in ---
GOOGLE_CLIENT_ID=__CHANGE_ME__
GOOGLE_CLIENT_SECRET=__CHANGE_ME__
# Apple — see README "Social sign-in" for how to obtain each value.
APPLE_CLIENT_ID=__CHANGE_ME__
APPLE_TEAM_ID=__CHANGE_ME__
APPLE_KEY_ID=__CHANGE_ME__
APPLE_PRIVATE_KEY=__CHANGE_ME__

LOG_LEVEL=INFO
